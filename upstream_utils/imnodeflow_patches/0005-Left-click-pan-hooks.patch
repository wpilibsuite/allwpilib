From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Drew Williams <drew.williams@capstanmedical.com>
Date: Wed, 13 May 2026 09:00:00 -0700
Subject: [PATCH] Hooks for left-click canvas pan

Upstream binds canvas pan to middle-mouse drag, which is unreachable on
a Mac trackpad without a third-party utility. WPILib's filter designer
remaps `scroll_button` to Left and uses ImNodeFlow's editor with mixed
left-click semantics (node drag, link drag-out, selection, *and* pan).
Two issues stand between that config and a working pan:

1. The scroll handler in `end()` has no way to defer to the host for
   "is the user already doing something else with left-click." We add a
   `block_scroll` flag on `ContainedContextConfig` that the host sets
   per-frame from its own state (e.g. ImNodeFlow::isNodeDragged() ||
   isLinkDragging() || any node selected). When set, the scroll branch
   is skipped even if the button is being dragged.

2. `ImGui::IsAnyItemActive()` returns true the instant left-click lands
   anywhere in window void space, because ImGui sets `ActiveId` to the
   hovered window's `MoveId` for the duration of the press — and does so
   even with `ImGuiWindowFlags_NoMove` (imgui.cpp's
   `UpdateMouseMovingWindowEndFrame` documents this: the ID is kept
   alive purely to suppress hover bleed onto other windows). The
   existing `!m_anyItemActive` guard against panning while a widget is
   being held therefore kills left-pan every frame. Filter a bare
   `MoveId` out of the active-item check so left-pan can fire while
   still blocking pan when the user is truly interacting with a widget.

Also expose `ImNodeFlow::isLinkDragging()` so the host can include
link-drag-out in its `block_scroll` decision symmetrically with
`isNodeDragged()`.

Signed-off-by: Drew Williams <drew.williams@capstanmedical.com>
---
 include/ImNodeFlow.h  |  6 ++++++
 src/context_wrapper.h | 27 +++++++++++++++++++++++++--
 2 files changed, 31 insertions(+), 2 deletions(-)

diff --git a/include/ImNodeFlow.h b/include/ImNodeFlow.h
index 68dbdaff60000000000000000000000000000000..43d9bfc550000000000000000000000000000000 100644
--- a/include/ImNodeFlow.h
+++ b/include/ImNodeFlow.h
@@ -417,6 +417,12 @@ namespace ImFlow
          */
         [[nodiscard]] bool isNodeDragged() const { return m_draggingNode; }

+        /**
+         * @brief <BR>Get link drag-out status
+         * @return [TRUE] if the user is currently dragging a new link out of a pin
+         */
+        [[nodiscard]] bool isLinkDragging() const { return m_dragOut != nullptr; }
+
         /**
          * @brief <BR>Get current style
          * @return Reference to style variables
diff --git a/src/context_wrapper.h b/src/context_wrapper.h
index e1cec05c00000000000000000000000000000000..5d2d1a4360000000000000000000000000000000 100644
--- a/src/context_wrapper.h
+++ b/src/context_wrapper.h
@@ -83,6 +83,12 @@ struct ContainedContextConfig
     float default_zoom = 1.f;
     ImGuiKey reset_zoom_key = ImGuiKey_R;
     ImGuiMouseButton scroll_button = ImGuiMouseButton_Middle;
+    // External pan suppression. When true, the scroll/pan handler in end()
+    // is skipped for this frame, even if scroll_button is being dragged. Hosts
+    // use this to prevent left-click pan from fighting with other left-click
+    // gestures (node drag, link drag-out, selection) when scroll_button is
+    // remapped to Left.
+    bool block_scroll = false;
 };

 class ContainedContext
@@ -167,7 +173,24 @@ inline void ContainedContext::end()
     if (m_config.extra_window_wrapper && ImGui::IsWindowHovered())
         m_anyWindowHovered = false;

-    m_anyItemActive = ImGui::IsAnyItemActive();
+    // ImGui::IsAnyItemActive() is a false positive for left-click pan: on
+    // any left-click in window void space, ImGui sets ActiveId to the
+    // hovered window's MoveId (see UpdateMouseMovingWindowEndFrame), even
+    // when the window has ImGuiWindowFlags_NoMove — the ID is kept alive
+    // for the duration of the press purely to suppress hover bleed onto
+    // other windows. With scroll_button remapped to Left, that drops pan
+    // every frame the user is mid-drag. Treat a bare MoveId as "no active
+    // item" so left-pan can fire while still blocking pan when the user
+    // is really interacting with a widget (button/slider/etc.).
+    {
+        ImGuiContext& sub_g = *ImGui::GetCurrentContext();
+        bool active = sub_g.ActiveId != 0;
+        if (active && sub_g.ActiveIdWindow &&
+            sub_g.ActiveIdWindow->MoveId == sub_g.ActiveId) {
+            active = false;
+        }
+        m_anyItemActive = active;
+    }

     if (m_config.extra_window_wrapper)
         ImGui::End();
@@ -215,7 +238,7 @@ inline void ContainedContext::end()
         m_scaleTarget = m_config.default_zoom;

     // Scrolling
-    if (m_hovered && !m_anyItemActive && ImGui::IsMouseDragging(m_config.scroll_button, 0.f))
+    if (!m_config.block_scroll && m_hovered && !m_anyItemActive && ImGui::IsMouseDragging(m_config.scroll_button, 0.f))
     {
         m_scroll += ImGui::GetIO().MouseDelta / m_scale;
         m_scrollTarget = m_scroll;
