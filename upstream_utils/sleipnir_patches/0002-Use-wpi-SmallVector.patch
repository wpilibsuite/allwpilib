   /// @param expr The autodiff variable.
-  explicit constexpr Variable(detail::ExpressionPtr<Scalar>&& expr)
+  explicit Variable(detail::ExpressionPtr<Scalar>&& expr)
       : expr{std::move(expr)} {}
 
   /// Assignment operator for scalar.
